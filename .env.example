OPENAI_API_KEY=

# Whisper model: tiny | base | small | medium | large-v3
V2C_ASR_MODEL=tiny

# Compute device for Whisper: cpu | cuda | mps
V2C_ASR_DEVICE=cpu

# WebRTC Voice Activity Detection aggressiveness 0-3 (higher = more aggressive)
V2C_VAD_AGGRESSIVENESS=2

# Audio sample rate in Hz (must be 8000, 16000, 32000, or 48000 for VAD)
V2C_SAMPLE_RATE=16000

# WebSocket server port for VS Code extension bridge
V2C_WS_PORT=6789

# Enable post-ASR LLM refinement (requires OPENAI_API_KEY when true)
V2C_REFINE_ENABLED=true

# LLM model for refinement and semantic command parsing
V2C_LLM_MODEL=gpt-4o-mini

# Logging level: DEBUG | INFO | WARNING | ERROR
V2C_LOG_LEVEL=INFO
